{
  "name": "@heroor/tpm",
  "version": "0.1.0",
  "description": "TPM is a typings package manager for npm, pnpm, yarn and bun projects",
  "author": "Bener",
  "license": "MIT",
  "main": "./dist/index.mjs",
  "type": "module",
  "bin": {
    "tpm": "./bin/tpm"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "tsdown && node --test test/*.test.mjs",
    "dev": "tsdown -w"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "bin"
  ],
  "packageManager": "pnpm@11.2.2"
}
